---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import BackToPrev from "@components/BackToPrev.astro";
import { readingTime } from "@lib/utils";

export async function getStaticPaths() {
  const notes = await getCollection("brain");
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: note,
  }));
}

type Props = CollectionEntry<"brain">;

const note = Astro.props;
const { Content } = await note.render();
const title = note.data.title ?? note.slug;
const description = note.data.description ?? "";
---

<PageLayout title={title} description={description}>
  <Container>
    <div class="animate">
      <BackToPrev href="/brain">
        Back to second brain
      </BackToPrev>
    </div>
    <div class="space-y-1 my-10">
      <div class="animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          {readingTime(note.body)}
        </div>
      </div>
      <div class="animate text-2xl font-semibold text-black 
dark:text-white">
        {title}
      </div>
    </div>
    <article class="animate">
      <Content />
    </article>
  </Container>
</PageLayout>
