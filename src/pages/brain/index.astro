---
import { getEntry } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { BRAIN } from "@consts";

const note = await getEntry("brain", "my-12-favorite-problems");
const { Content } = note ? await note.render() : { Content: null };
---

<PageLayout title={BRAIN.TITLE} description={BRAIN.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <div class="animate flex justify-end">
        <Link href="/brain/directory">Browse all notes</Link>
      </div>
      <article class="animate prose dark:prose-invert">
        {Content ? <Content /> : null}
      </article>
      <div class="animate flex justify-end">
        <Link href="/brain/directory">Browse all notes</Link>
      </div>
    </div>
  </Container>
</PageLayout>
